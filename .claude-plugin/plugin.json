{
  "name": "socrata-mcp-server",
  "version": "0.1.8",
  "description": "Search and query government open-data portals (Socrata SODA API) via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/socrata-mcp-server#readme",
  "repository": "https://github.com/cyanheads/socrata-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "socrata-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/socrata-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "SOCRATA_APP_TOKEN": "",
        "SOCRATA_DEFAULT_DOMAIN": "data.seattle.gov"
      }
    }
  }
}
